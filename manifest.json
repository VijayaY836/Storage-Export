{
  "manifest_version": 3,
  "name": "Storage Explorer",
  "version": "1.0.0",
  "description": "Explore and manage localStorage, sessionStorage, and cookies for the current site.",
  "permissions": ["activeTab", "scripting", "cookies"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Storage Explorer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}